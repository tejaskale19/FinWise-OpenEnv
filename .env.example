# FinWise OpenEnv — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to GitHub

# ── MANDATORY for inference.py ──────────────────
# Your Hugging Face API token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=YOUR_TOKEN_HERE

# LLM API endpoint (default: HF Inference Router)
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for inference
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Optional local image override used by some validators/runners
LOCAL_IMAGE_NAME=

# ── OPTIONAL ─────────────────────────────────────
# Port for local development (default: 7860 for HF Spaces)
PORT=7860

# If using OpenAI directly instead of HF Router
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# API_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini